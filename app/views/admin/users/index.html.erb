<h1>ユーザー一覧</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>名前</th>
      <th>Email</th>
      <th>管理者</th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.admin? ? "○" : "-" %></td>
        <td>
          <%= link_to "詳細", admin_user_path(user) %> |
          <%= link_to "編集", edit_admin_user_path(user) %> |
          <%= link_to "削除", admin_user_path(user),
                method: :delete,
                data: { confirm: "本当に削除しますか？" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "新規作成", new_admin_user_path %>