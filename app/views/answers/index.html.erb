<h1>回答履歴</h1>
<table>
  <thead>
    <tr>
      <th>問題</th>
      <th>あなたの回答</th>
      <th>正解</th>
      <th>結果</th>
    </tr>
  </thead>
  <tbody>
    <% @answers.each do |answer| %>
      <tr>
        <td><%= answer.question.question_text %></td>
        <td><%= answer.selected_answer %></td>
        <td><%= answer.question.correct_answer %></td>
        <td>
          <% if answer.selected_answer == answer.question.correct_answer %>
            <span style="color: green;">正解</span>
          <% else %>
            <span style="color: red;">不正解</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>