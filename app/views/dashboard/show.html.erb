<div class="container mt-5">
  <h2 class="mb-4 text-center">ダッシュボード</h2>
  <div class="card mb-4">
    <div class="card-body text-center">
      <h4>総合成績</h4>
      <p><%= @correct %> / <%= @total %> 問</p>
      <div class="row text-center mb-4">
        <div class="col-md-4">
          <div class="card shadow-sm p-3">
            <h6>回答数</h6>
            <p><%= @total %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm p-3">
            <h6>正解数</h6>
            <p class="text-success"><%= @correct %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm p-3">
            <h6>正答率</h6>
            <p class="text-primary"><%= @accuracy %>%</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="card mb-4">
    <div class="card-body">
      <h4>カテゴリ別成績</h4>
      <% @category_status.each do |category| %>
        <% color =
          if category[:accuracy] >= 80
            "bg-success"
          elsif category[:accuracy] >= 50
            "bg-warning"
          else
            "bg-danger"
          end
        %>
        <div class="mb-3">
          <strong><%= category[:name] %></strong>
          <div class="progress mb-2">
            <div class="progress-bar <%= color %>" style="width: <%= category[:accuracy] %>%"> <%= category[:accuracy] %>%</div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <div class="card mb-4">
    <div class="card-body">
      <h4>苦手分野</h4>
      <% @weak_categories.each do |category| %>
        <p><%= category[:name] %> (<%= category[:accuracy] %>%) </p>
        <p><%= link_to "苦手問題へ", weak_questions_path, class: "btn btn-danger" %>
      <% end %>
    </div>
  </div>
  <div class="card">
    <div class="card-body">
      <h4>最近の回答</h4>
      <ul class="list-group">
        <% @recent_answers.each do |answer| %>
          <li class="list-group-item d-flex justify-content-between">
            <span><%= link_to answer.question.question_text, question_path(answer.question) %></span>
            <% if answer.correct? %>
              <span class="text-success">正解</span>
            <% else %>
              <span class="text-danger">不正解</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>