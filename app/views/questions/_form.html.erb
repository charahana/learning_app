<%= form_with model: question do |f| %>
  <div class="form-group">
    <%= f.label :category_id, "カテゴリ" %>
    <%= f.collection_select :category_id, Category.all, :id, :name, { prompt: "選択してください" }, { class: "form-control" } %>
  </div>
  <div class="form-group">
    <%= f.label :question_text, "問題文" %>
    <%= f.text_area :question_text, class: "form-control", rows: 3 %>
  </div>
  <h3>選択肢</h3>
  <%= f.fields_for :choices do |cf| %>
    <div class="form-row align-items-center mb-2">
      <div class="col-md-8">
        <%= cf.label :content, "選択肢" %>
        <%= cf.text_field :content, class: "form-control" %>
      </div>
      <div class="col-md-2 mt-4">
        <div class="form-check">
          <%= cf.check_box :is_correct, class: "form-check-input" %>
          <%= cf.label :is_correct, "正解", class: "form-check-label" %>
        </div>
      </div>
    </div>
  <% end %>
  <div class="form-group">
    <%= f.label :explanation, "解説" %>
    <%= f.text_area :explanation, class: "form-control", rows: 3 %>
  </div>
  <div class="form-group mt-3">
    <%= f.submit "保存", class: "btn btn-primary" %>
  </div>
<% end %>