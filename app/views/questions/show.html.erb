<h3>回答する</h3>
<%= form_with url: question_answers_path(@question), method: :post do %>
  <% @question.choices.each do |choice| %>
    <div>
      <label>
        <%= f.radio_button :choice_id, choice.id %>
        <%= choice.content %>
      </label>
    </div>
  <% end %>
  <% if @question.answers.where(user: current_user).exists? %>
    <% answer = @question.answers.where(user: current_user) %>
    <p>あなたの回答: <%= answer.choice.content %></p>
    <% if answer.choice.is_correct %>
      <p style="color:green">正解です！</p>
    <% else %>
      <p style="color:red">不正解</p>
      <p>正解: <%= @question.choices.find_by(is_correct: true).content %></p>
    <% end %>
    <p>解説: <%= @question.explanation %></p>
  <% end %>
<% end %>